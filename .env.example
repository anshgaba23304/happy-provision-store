# MongoDB Atlas connection string (required for production).
# Use quotes because the URI contains & characters.
# If mongodb+srv fails with DNS errors on macOS, use Atlas "Standard connection string" instead:
# MONGODB_URI="mongodb://USER:PASS@host1:27017,host2:27017,host3:27017/happy-provision-store?ssl=true&replicaSet=atlas-xxx-shard-0&authSource=admin&retryWrites=true&w=majority"
MONGODB_URI="mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/happy-provision-store?retryWrites=true&w=majority"

# Optional: override admin PIN (default in application.properties)
# APP_ADMIN_PIN=
