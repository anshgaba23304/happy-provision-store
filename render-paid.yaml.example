# Use this instead of render.yaml if you upgrade to a paid Render plan ($7+/mo).
# Rename to render.yaml or create the service manually with a disk attached.

services:
  - type: web
    name: happy-provision-store
    runtime: docker
    plan: starter
    dockerfilePath: ./Dockerfile
    disk:
      name: happy-store-data
      mountPath: /app/persist
      sizeGB: 1
    envVars:
      - key: PORT
        value: 8080
      - key: STORE_DATA_PATH
        value: /app/persist/data
      - key: STORE_UPLOAD_PATH
        value: /app/persist/uploads
